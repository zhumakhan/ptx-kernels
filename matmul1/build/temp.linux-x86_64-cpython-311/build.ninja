ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-13/bin/nvcc

cflags = -pthread -B /home/ubuntu/miniconda3/envs/py311/compiler_compat -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/ubuntu/miniconda3/envs/py311/include -fPIC -O2 -isystem /home/ubuntu/miniconda3/envs/py311/include -fPIC -I/home/ubuntu/miniconda3/envs/py311/lib/python3.11/site-packages/torch/include -I/home/ubuntu/miniconda3/envs/py311/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-13/include -I/home/ubuntu/miniconda3/envs/py311/include/python3.11 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=matmul1 -std=c++17
cuda_cflags = -I/home/ubuntu/miniconda3/envs/py311/lib/python3.11/site-packages/torch/include -I/home/ubuntu/miniconda3/envs/py311/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-13/include -I/home/ubuntu/miniconda3/envs/py311/include/python3.11 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -arch=sm_90a -std=c++17 --expt-relaxed-constexpr -lcuda -O3 --use_fast_math -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=matmul1
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /home/ubuntu/SageAttention/matmul/build/temp.linux-x86_64-cpython-311/matmul1.o: cuda_compile /home/ubuntu/SageAttention/matmul/matmul1.cu








